# Matte Black Fish Colors
set -U fish_color_normal bebebe
set -U fish_color_command FFC107
set -U fish_color_keyword D35F5F
set -U fish_color_quote e68e0d
set -U fish_color_redirection bebebe
set -U fish_color_end b91c1c
set -U fish_color_error D35F5F
set -U fish_color_param e68e0d
set -U fish_color_comment 8a8a8d
set -U fish_color_selection --background=333333
set -U fish_color_search_match --background=333333
set -U fish_color_operator FFC107
set -U fish_color_escape D35F5F
set -U fish_color_autosuggestion 8a8a8d

set -U fish_pager_color_progress 8a8a8d
